# Backend environment variables
# Copy this file to .env and fill in your values

# --- Google Gemini (LLM + Embeddings via OpenAI-compatible endpoint) ---
GOOGLE_API_KEY=your-google-ai-studio-api-key-here

# --- Qdrant Cloud (Vector Database for RAG) ---
QDRANT_URL=https://your-cluster.us-east4-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key-here

# --- Neon Postgres (Auth, Cache, Chat History) ---
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# --- Application Configuration ---
APP_ENV=development
JWT_SECRET=your-jwt-secret-here

# --- CORS Origins (comma-separated) ---
# Local dev:
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# Production (Railway) — MUST include your GitHub Pages domain:
CORS_ORIGINS=https://abdullahzunorain.github.io, http://localhost:3000,http://localhost:3001
